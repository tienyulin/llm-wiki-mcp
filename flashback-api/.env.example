# flashback-api configuration. Copy to .env and fill in.
# Example upstream app (Oracle Flashback Recovery API).

MOCK_ORACLE=true            # true = in-memory mock; false = real Oracle (set ORACLE_* below)
ORACLE_DSN=
ORACLE_USER=
ORACLE_PASSWORD=
FLASHBACK_API_KEY=          # empty = unauthenticated (dev)
FRA_USAGE_THRESHOLD=85
