# LLM Wiki System Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# Minimax API (Required for wiki-processor)
# Get your API key from: https://platform.minimaxi.com
MINIMAX_API_KEY=your-minimax-api-key-here

# Minio Configuration
# Default values are fine for local development
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wiki-data

# Optional: Minio Security
# Set to 'true' if using HTTPS/TLS
# MINIO_SECURE=false
