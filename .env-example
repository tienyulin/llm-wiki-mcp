# LLM Wiki System Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# ============================================================
# LLM Provider Configuration
# ============================================================
# Set LLM_PROVIDER to one of:
#   minimax           - Minimax AI (default, backward-compatible)
#   openai            - OpenAI (GPT-4, etc.)
#   anthropic         - Anthropic Claude
#   gemini            - Google Gemini
#   groq              - Groq (fast inference)
#   azure             - Azure OpenAI
#   openai-compatible - Any OpenAI-compatible API (Ollama, vLLM, LM Studio, etc.)

LLM_PROVIDER=minimax

# API key for the selected provider
# (not required for openai-compatible with local services)
LLM_API_KEY=your-api-key-here

# Model name (defaults per provider if not set)
# Minimax default:   MiniMax-M2.7
#   (international API at api.minimax.io also serves MiniMax-M3 / MiniMax-M2)
# OpenAI default:    gpt-4-turbo
# Anthropic default: claude-opus-4-7
# Gemini default:    gemini-2.0-flash
# Groq default:      mixtral-8x7b-32768
# LLM_MODEL=

# Optional settings (defaults shown)
# LLM_TEMPERATURE=0.7
# LLM_MAX_TOKENS=4000
# LLM_TIMEOUT=60

# For openai-compatible only - set the base URL of your LLM service:
# Ollama:     LLM_BASE_URL=http://localhost:11434
# vLLM:       LLM_BASE_URL=http://llm-server:8000
# LM Studio:  LLM_BASE_URL=http://localhost:1234
# LLM_BASE_URL=

# Enable mock LLM for testing (no real API calls)
MOCK_LLM=false

# ============================================================
# Provider-specific examples (uncomment to use)
# ============================================================

# -- OpenAI --
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-proj-...
# LLM_MODEL=gpt-4-turbo

# -- Anthropic Claude --
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-opus-4-7

# -- Google Gemini --
# LLM_PROVIDER=gemini
# LLM_API_KEY=AIzaSy...
# LLM_MODEL=gemini-2.0-flash

# -- Groq --
# LLM_PROVIDER=groq
# LLM_API_KEY=gsk_...
# LLM_MODEL=mixtral-8x7b-32768

# -- Azure OpenAI --
# LLM_PROVIDER=azure
# LLM_API_KEY=your-azure-key
# LLM_BASE_URL=https://{resource}.openai.azure.com
# LLM_MODEL=gpt-4   (deployment name)
# AZURE_API_VERSION=2024-02-01

# -- Self-hosted Ollama --
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=not-needed
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=llama2

# -- Self-hosted vLLM --
# LLM_PROVIDER=openai-compatible
# LLM_API_KEY=token-123
# LLM_BASE_URL=http://llm-server:8000
# LLM_MODEL=mistral-7b

# ============================================================
# Minio Configuration
# ============================================================
# Default values work for local development
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wiki-data

# Optional: set to 'true' if using HTTPS/TLS
# MINIO_SECURE=false

# ============================================================
# Backward Compatibility
# ============================================================
# If you previously used MINIMAX_API_KEY, it still works as fallback:
# MINIMAX_API_KEY=sk-cp-...

# ============================================================
# Security
# ============================================================
# API key required by POST /process (X-API-Key header).
# Leave unset for unauthenticated dev mode (a startup warning is logged).
# PROCESSOR_API_KEY=change-me

# mcp-server rate limit (requests/second per client IP; 0 = disabled)
# RATE_LIMIT_RPS=0

# ============================================================
# Vector Index (Postgres + pgvector) — optional
# ============================================================
# Empty PG_DSN = layer disabled; system behaves exactly as before.
# With docker compose --profile pg (single pgvector instance):
# PG_DSN=postgresql://wiki:wikipass@pg:5432/wiki
# Single local Postgres:
# PG_DSN=postgresql://postgres:pg@localhost:5432/wiki
# Multi-host HA DSNs also work unchanged (future cluster, no code change):
# PG_DSN=postgresql://wiki:pw@host-a:5432,host-b:5432/wiki?target_session_attrs=read-write

# Connection pool / circuit breaker (defaults shown)
# PG_POOL_MIN=1
# PG_POOL_MAX=10
# PG_RETRY_SECONDS=30

# Embeddings: any OpenAI-compatible /v1/embeddings endpoint
# (OpenAI, Ollama, vLLM, text-embeddings-inference, ...).
# Unset EMBEDDING_BASE_URL = entries sync relationally without vectors
# (keyword search works, /semantic_search falls back to keyword).
# EMBEDDING_BASE_URL=https://api.openai.com
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIM=1536          # must match the model; changing it requires
#                             # dropping the tables + POST /admin/reindex
# EMBEDDING_BATCH_SIZE=64
# EMBEDDING_TIMEOUT=30

# Deterministic local vectors for testing (no network; counts as enabled)
MOCK_EMBEDDINGS=false

# Compose profile pg credentials (defaults shown)
# PG_USER=wiki
# PG_PASSWORD=wikipass
# PG_DATABASE=wiki
