# mcp-server configuration. Copy to .env and fill in.
# Read-only query service — only this service's variables.

# -- MinIO (read the wiki) ----------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=wiki-data

# -- PG + pgvector (read the index; empty = MinIO scan fallback) ---------------
PG_DSN=postgresql://wiki:wikipass@pg:5432/wiki
PG_RETRY_SECONDS=30

# -- Query-side embeddings (must match the processor's model/dim) --------------
EMBEDDING_BASE_URL=               # OpenAI-compatible /v1/embeddings root (empty = mock)
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536
EMBEDDING_SEND_DIMENSIONS=false   # true for Gemini gemini-embedding-001
MOCK_EMBEDDINGS=true
